[32m+[m[32m          if (playerChoice == sequence.size())[m
[32m+[m[32m          {[m
[32m+[m[32m            displayDelay -= 20;[m
[32m+[m[32m            delay(500);[m
[32m+[m[32m            state = SHOW_SEQUENCE;[m
[32m+[m[32m          }[m
[32m+[m[32m        }[m
[32m+[m[32m        else[m
[32m+[m[32m        {[m
[32m+[m[32m          state = GAME_OVER;[m
[32m+[m[32m        }[m
