[32m+[m[32m}[m
[32m+[m
[32m+[m[32mvoid LightSequence()[m
[32m+[m[32m{[m
[32m+[m[32m  for (int i : sequence)[m
[32m+[m[32m  {[m
[32m+[m[32m    PlayTone(i);[m
[32m+[m
[32m+[m[32m    TurnOnLed(i);[m
[32m+[m[32m    delay(displayDelay);[m
[32m+[m[41m    [m
[32m+[m[32m    TurnOffLed(i);[m
[32m+[m[32m    delay(displayDelay);[m
[32m+[m[32m  }[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mint CheckChoice()[m
[32m+[m[32m{[m
[32m+[m[32m  static unsigned long lastPressTime = 0;[m
[32m+[m
[32m+[m[32m  if (millis() - lastPressTime < 50)[m
[32m+[m[32m    return -1;[m
[32m+[m
[32m+[m[32m  for (int i = 0; i < 3; i++)[m
[32m+[m[32m  {[m
[32m+[m[32m    if (IsButtonPressed(i))[m
