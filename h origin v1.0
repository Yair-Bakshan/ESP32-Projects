[32m+[m
[32m+[m[32m    case PLAYER_INPUT:[m
[32m+[m[32m    {[m
[32m+[m[32m      int choice = CheckChoice();[m
[32m+[m
[32m+[m[32m      if (millis() - lastInputTime > timeout)[m
[32m+[m[32m        state = GAME_OVER;[m
[32m+[m
[32m+[m[32m      if (choice != -1)[m
[32m+[m[32m      {[m
[32m+[m[32m        lastInputTime = millis();[m
[32m+[m
[32m+[m[32m        if (choice == sequence.at(playerChoice))[m
[32m+[m[32m        {[m
[32m+[m[32m          playerChoice++;[m
