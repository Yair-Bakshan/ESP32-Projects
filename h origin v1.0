[32m+[m[32m    pinMode(button, INPUT_PULLUP);[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mvoid loop()[m
[32m+[m[32m{[m
[32m+[m[32m  switch (state)[m
[32m+[m[32m  {[m
[32m+[m
[32m+[m[32m    case SHOW_SEQUENCE:[m
[32m+[m
[32m+[m[32m      AddToSequence();[m
[32m+[m[32m      LightSequence();[m
[32m+[m[32m      playerChoice = 0;[m
[32m+[m[32m      lastInputTime = millis();[m
[32m+[m
[32m+[m[32m      state = PLAYER_INPUT;[m
[32m+[m
