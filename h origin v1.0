[1mdiff --git a/Button Light/Button_Light.ino b/Button Light/Button_Light.ino[m
[1mnew file mode 100644[m
[1mindex 0000000..a4e1727[m
[1m--- /dev/null[m
[1m+++ b/Button Light/Button_Light.ino[m	
[36m@@ -0,0 +1,13 @@[m
[32m+[m[32mconst int buttonPin = 4;[m
[32m+[m[32mconst int ledPin = 5;[m
[32m+[m
[32m+[m[32mvoid setup() {[m
[32m+[m[32m  pinMode(buttonPin, INPUT_PULLUP);[m
[32m+[m[32m  pinMode(ledPin, OUTPUT);[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mvoid loop() {[m
[32m+[m[32m  int buttonState = digitalRead(buttonPin);[m
[32m+[m[32m  int useCase = buttonState == LOW ? HIGH : LOW;[m
[32m+[m[32m  digitalWrite(ledPin, useCase);[m
[32m+[m[32m}[m
\ No newline at end of file[m
[1mdiff --git a/Controller/Controller.ino b/Controller/Controller.ino[m
[1mnew file mode 100644[m
[1mindex 0000000..fc90d74[m
[1m--- /dev/null[m
[1m+++ b/Controller/Controller.ino[m
[36m@@ -0,0 +1,45 @@[m
[32m+[m[32m#define PIN_VRX  15[m
[32m+[m[32m#define PIN_VRY  2[m
[32m+[m[32m#define PIN_POT  4[m
[32m+[m
[32m+[m[32m#define DEAD_ZONE 0.35[m
[32m+[m
[32m+[m[32mvoid setup() {[m
[32m+[m[32m  Serial.begin(115200);[m
[32m+[m[32m  analogReadResolution(12);[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mfloat normaliseAxis(int raw) {[m
[32m+[m[32m  float value = (raw / 4095.0) * 2.0 - 1.0;[m
[32m+[m
[32m+[m[32m  if (fabs(value) < DEAD_ZONE) {[m
[32m+[m[32m    value = 0.0;[m
[32m+[m[32m  }[m
[32m+[m
[32m+[m[32m  return value;[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32m// Returns -1.0 to 1.0[m
[32m+[m[32mfloat getX() {[m
[32m+[m[32m  return normaliseAxis(analogRead(PIN_VRX));[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32m// Returns -1.0 to 1.0  (up = positive)[m
[32m+[m[32mfloat getY() {[m
[32m+[m[32m  return normaliseAxis(analogRead(PIN_VRY));[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32m// Returns 0.0 to 360.0[m
[32m+[m[32mfloat getRot() {[m
[32m+[m[32m  return ((float)analogRead(PIN_POT) / 4095.0) * 360.0f;[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mvoid loop() {[m
[32m+[m[32m  // Example usage — replace with your own logic[m
[32m+[m[32m  Serial.print(getX());[m[41m   [m
[32m+[m[32m  Serial.print(',');[m
[32m+[m[32m  Serial.print(getY());[m[41m  [m
[32m+[m[32m  Serial.print(',');[m
[32m+[m[32m  Serial.println(getRot());[m
[32m+[m[32m  delay(16);[m
[32m+[m[32m}[m
