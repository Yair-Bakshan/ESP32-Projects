[32m+[m
[32m+[m[32mvoid TurnOffLed(int index)[m
[32m+[m[32m{[m
[32m+[m[32m  digitalWrite(leds[index], LOW);[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mvoid PlayTone(int index) {[m
[32m+[m[32m  tone(buzzerPin, freqs[index], displayDelay);[m[41m [m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32mbool IsButtonPressed(int index)[m
[32m+[m[32m{[m
